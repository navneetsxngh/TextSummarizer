# ── Version control ─────────────────────────────────────────────────
.git
.gitignore
.gitattributes
.github

# ── Python bytecode / caches ─────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
*.pyo

# ── Virtual environments ─────────────────────────────────────────────
TSenv/
.env
.env.*
.venv
env/
venv/
ENV/

# ── Testing & coverage ───────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage*.xml
*.cover
nosetests.xml
test-results/

# ── ML artefacts (downloaded / mounted at runtime; never baked in) ───
artifacts/
models/
*.bin
*.safetensors
*.ckpt
*.pth
*.pt
*.h5
*.onnx

# ── Jupyter notebooks ─────────────────────────────────────────────────
research/
*.ipynb
.ipynb_checkpoints/

# ── Logs ──────────────────────────────────────────────────────────────
*.log
logs/

# ── Documentation & markdown ─────────────────────────────────────────
*.md
docs/

# ── OS artefacts ──────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── IDE / editor configs ──────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
.editorconfig

# ── Docker files (no need to copy Dockerfile into itself) ────────────
Dockerfile
.dockerignore

# ── CI/CD ─────────────────────────────────────────────────────────────
.github/

# ── Tool configs (no runtime value) ──────────────────────────────────
setup.cfg
pyproject.toml
.flake8
.bandit
bandit-report.json

# ── Dataset & data files ──────────────────────────────────────────────
data/
*.csv
*.json
*.parquet
*.arrow
*.tsv
*.zip
*.tar.gz
*.7z
